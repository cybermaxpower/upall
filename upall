#!/bin/bash

# ==============================================================================
# Script Name:  upall
# Description:  Automated universal system updater for Linux. Automatically
#               detects the OS base (Debian/Ubuntu or Arch) and safely handles
#               APT, Pacman/AUR, Snap, and Flatpak updates with built-in checks.
# Author:       Matt / https://github.com/cybermaxpower/
# License:      MIT License 
# Version:      1.2.1
# Date:         2026-06-26
# ==============================================================================


# Clear the screen for a professional start  
clear 

# ==========================================
# 1. DETECT OPERATING SYSTEM / PACKAGER
# ==========================================
# We check which package manager is available to determine the OS base.
if command -v apt &> /dev/null; then
    PKG_MANAGER="apt"
elif command -v pacman &> /dev/null; then
    PKG_MANAGER="pacman"
else
    # If neither is found, print a clear error and halt everything immediately
    echo -e "\e[31m[CRITICAL ERROR]\e[0m No supported package manager (APT or Pacman) found."
    echo -e "This script is not compatible with your operating system. Exiting safely."
    exit 1
fi

# ==========================================
# 2. SYSTEM UPDATES
# ==========================================
echo -e "╔═════════════════════════════════════════════════════╗"
echo -e "║        \e[32mStarting Full System Update...\e[0m               ║"
echo -e "╚═════════════════════════════════════════════════════╝"
echo -e "\n"

# Because of the 'exit 1' above, we are 100% guaranteed to only be on APT or Pacman here
if [ "$PKG_MANAGER" = "apt" ]; then
    echo -e "\e[32m[DETECTED]\e[0m Debian/Ubuntu-based system."
    sudo apt update && sudo apt full-upgrade -y

elif [ "$PKG_MANAGER" = "pacman" ]; then
    echo -e "\e[32m[DETECTED]\e[0m Arch-based system."
    
    if command -v yay &> /dev/null; then
        echo -e "\e[34m[AUR]\e[0m Updating with yay..."
        yay -Syu --noconfirm
    elif command -v paru &> /dev/null; then
        echo -e "\e[34m[AUR]\e[0m Updating with paru..."
        paru -Syu --noconfirm
    else
        sudo pacman -Syu --noconfirm
    fi
fi

echo -e "\n"



# ==========================================
# 3. SNAP UPDATES (Conditional & Silent)
# ==========================================
# This checks if snap is installed AND if the snap background service is actively running.
# This prevents scary connection errors on systems like BigLinux.
if command -v snap &> /dev/null && systemctl is-active --quiet snapd; then
    echo -e "╔═════════════════════════════════════════════════════╗"
    echo -e "║                 \e[34mRefreshing Snaps...\e[0m                 ║"
    echo -e "╚═════════════════════════════════════════════════════╝"
    echo -e "\n"
    
    # Refreshes (updates) all installed snap packages
    sudo snap refresh
    echo -e "\n"
fi

# ==========================================
# 4. FLATPAK UPDATES (Conditional)
# ==========================================
# The header and commands will now ONLY trigger if the 'flatpak' command actually exists.
if command -v flatpak &> /dev/null; then
    echo -e "╔═════════════════════════════════════════════════════╗"
    echo -e "║                \e[35mUpdating Flatpaks...\e[0m                 ║"
    echo -e "╚═════════════════════════════════════════════════════╝"
    echo -e "\n"
    
    # Updates all flatpaks. 
    # '2>&1' merges errors into standard output so grep can filter out annoying End-of-Life (EOL) warnings.
    flatpak update -y 2>&1 | grep -vE "end-of-life|receiving fixes|applications using|extension:"

    # Automatically removes any leftover Flatpak runtimes or libraries that are no longer needed.
    # '> /dev/null 2>&1' keeps this step completely silent.
    flatpak uninstall --unused -y > /dev/null 2>&1
    echo -e "\n"
fi

# ==========================================
# 5. FINISH
# ==========================================
# Final success message indicating the script has successfully reached the end.
echo -e "╔═════════════════════════════════════════════════════╗"
echo -e "║               \e[32mALL UPDATES COMPLETE!\e[0m                 ║"
echo -e "╚═════════════════════════════════════════════════════╝"
echo -e "\n"
